{
  "manifest_version": 3,
  "name": "Smart Element for Thunderbird",
  "version": "1.0.101",
  "description": "Open Element Web in a Thunderbird tab with Smart Element enhancements.",
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://matrix.helmholtz.cloud/*",
    "https://*.element.io/*",
    "https://matrix.helmholtz.cloud/*",
    "https://matrix-client.matrix.org/*",
    "https://*/_matrix/*",
    "http://*/_matrix/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "preferred_environment": [
      "document"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "mg-page-bridge.js",
        "mmi-page-bridge.js"
      ],
      "matches": [
        "https://matrix.helmholtz.cloud/*",
        "https://*.element.io/*",
        "https://matrix.helmholtz.cloud/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://matrix.helmholtz.cloud/*",
        "https://*.element.io/*",
        "https://matrix.helmholtz.cloud/*"
      ],
      "js": [
        "combined-settings.js",
        "gallery-content.js",
        "mattermost-importer-content.js",
        "matrix-mobile-content.js"
      ],
      "css": [
        "gallery-styles.css",
        "mattermost-importer-styles.css",
        "matrix-mobile-styles.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "combined-settings.js",
        "mattermost-exporter-content.js"
      ],
      "css": [
        "mattermost-exporter-content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "smart-element-thunderbird@t-kluge.de",
      "strict_min_version": "121.0"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Open Smart Element"
  }
}
